# GitHub Token (需要 repo 和 pull_request 权限)
GITHUB_TOKEN=

# AI 提供商: deepseek / claude / zhipu
AI_PROVIDER=deepseek

# AI API Key
AI_API_KEY=

# AI API Base URL (一般无需修改, 会根据 AI_PROVIDER 自动选择)
# AI_BASE_URL=https://api.deepseek.com

# AI 模型选择
#   deepseek: deepseek-chat
#   claude: claude-sonnet-4-6
#   zhipu: glm-5
AI_MODEL=deepseek-chat

# 审查模式: incremental (只分析新增代码) / full (分析完整 diff)
REVIEW_MODE=incremental

# Review 语言: zh (中文, 默认) / en (English)
REVIEW_LANGUAGE=zh

# 最大输出 token 数
MAX_TOKENS=4096

# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# 每次 API 调用最大重试次数
MAX_RETRIES=3
